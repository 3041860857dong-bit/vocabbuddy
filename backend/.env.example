# VocabBuddy 后端环境变量示例
# 复制为 .env 后按需修改（.env 已被 .gitignore 忽略，不会进版本库）

# 数据库连接串（默认指向本地 MySQL）
VOCABBUDDY_DB_URL=mysql+pymysql://vocabbuddy:vocabbuddy@127.0.0.1:3306/vocabbuddy

# JWT 签名密钥（生产必须改成随机长字符串）
VOCABBUDDY_JWT_SECRET=change-me-to-a-long-random-string

# token 有效期（分钟）
VOCABBUDDY_JWT_EXPIRE_MINUTES=60
