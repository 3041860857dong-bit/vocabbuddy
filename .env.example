# VocabBuddy 根环境变量模板（供 backend/config.py 的 load_dotenv() 读取）
#
# 用法：复制本文件为 .env 并按本机环境修改。
# 重要：.env 已被 .gitignore 忽略，绝不会进入版本库；仓库只保留本模板。

# 数据库连接串（默认指向本地 MySQL 8）
VOCABBUDDY_DB_URL=mysql+pymysql://vocabbuddy:vocabbuddy@127.0.0.1:3306/vocabbuddy

# JWT 签名密钥（生产务必改成随机长字符串，可用 `openssl rand -hex 32` 生成）
VOCABBUDDY_JWT_SECRET=change-me-to-a-long-random-string

# token 有效期（分钟）
VOCABBUDDY_JWT_EXPIRE_MINUTES=1440

# ===== 大模型（混淆项 / 同义词生成，OpenAI 兼容） =====
# 留空则自动降级为「从同词库随机抽其他词的中文释义」兜底，不影响学习。
# 填入 DeepSeek key（以 sk- 开头）即启用大模型；也可切换为 OpenAI / 通义千问 / 智谱 GLM。
VOCABBUDDY_LLM_API_KEY=
VOCABBUDDY_LLM_BASE_URL=https://api.deepseek.com/v1
VOCABBUDDY_LLM_MODEL=deepseek-chat
